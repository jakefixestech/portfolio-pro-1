---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us | Franconia Family Dental"
  description="Get in touch with Franconia Family Dental. Schedule an appointment, ask questions, or visit our office in Franconia, NH."
>
  <!-- Hero Section -->
  <section
    aria-labelledby="hero-heading"
    class="bg-gradient-to-br from-sky-600 to-sky-700 text-white py-16 md:py-20"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 id="hero-heading" class="text-4xl md:text-5xl font-bold mb-4 text-balance">
        Contact Us
      </h1>
      <p class="text-xl text-sky-100 max-w-2xl mx-auto text-pretty">
        We'd love to hear from you! Whether you have questions, need to schedule an appointment,
        or want to learn more about our services, our friendly team is here to help.
      </p>
    </div>
  </section>

  <!-- Contact Form & Info Section -->
  <section
    aria-labelledby="contact-section-heading"
    class="py-16 md:py-20 bg-white"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="contact-section-heading" class="sr-only">Contact Form and Office Information</h2>

      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Contact Form -->
        <div>
          <h3 id="form-heading" class="text-2xl font-bold text-slate-800 mb-6">
            Send Us a Message
          </h3>
          <form
            aria-labelledby="form-heading"
            class="space-y-6"
            action="/api/contact"
            method="POST"
          >
            <!-- Full Name -->
            <div>
              <label
                for="full-name"
                class="block text-sm font-medium text-slate-700 mb-2"
              >
                Full Name <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="full-name"
                name="fullName"
                required
                aria-required="true"
                autocomplete="name"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors duration-200"
                placeholder="John Smith"
              />
            </div>

            <!-- Email -->
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-slate-700 mb-2"
              >
                Email Address <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                aria-required="true"
                autocomplete="email"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors duration-200"
                placeholder="john@example.com"
              />
            </div>

            <!-- Phone -->
            <div>
              <label
                for="phone"
                class="block text-sm font-medium text-slate-700 mb-2"
              >
                Phone Number <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                aria-required="true"
                aria-describedby="phone-hint"
                autocomplete="tel"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors duration-200"
                placeholder="(555) 123-4567"
              />
              <p id="phone-hint" class="mt-1 text-sm text-slate-500">
                Format: (555) 123-4567
              </p>
            </div>

            <!-- Preferred Contact Method -->
            <fieldset>
              <legend class="block text-sm font-medium text-slate-700 mb-3">
                Preferred Contact Method <span class="text-red-500" aria-hidden="true">*</span>
              </legend>
              <div class="flex flex-wrap gap-6">
                <div class="flex items-center">
                  <input
                    type="radio"
                    id="contact-phone"
                    name="contactMethod"
                    value="phone"
                    required
                    aria-required="true"
                    class="h-4 w-4 text-sky-600 border-slate-300 focus:ring-2 focus:ring-sky-500"
                  />
                  <label for="contact-phone" class="ml-2 text-slate-700">
                    Phone Call
                  </label>
                </div>
                <div class="flex items-center">
                  <input
                    type="radio"
                    id="contact-email"
                    name="contactMethod"
                    value="email"
                    class="h-4 w-4 text-sky-600 border-slate-300 focus:ring-2 focus:ring-sky-500"
                  />
                  <label for="contact-email" class="ml-2 text-slate-700">
                    Email
                  </label>
                </div>
              </div>
            </fieldset>

            <!-- Service of Interest -->
            <div>
              <label
                for="service"
                class="block text-sm font-medium text-slate-700 mb-2"
              >
                Service of Interest
              </label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors duration-200 bg-white"
              >
                <option value="">Select a service (optional)</option>
                <option value="general-dentistry">General Dentistry</option>
                <option value="cosmetic-dentistry">Cosmetic Dentistry</option>
                <option value="pediatric-dentistry">Pediatric Dentistry</option>
                <option value="orthodontics">Orthodontics</option>
                <option value="emergency-dental-care">Emergency Dental Care</option>
                <option value="teeth-whitening">Teeth Whitening</option>
              </select>
            </div>

            <!-- Preferred Appointment Date -->
            <div>
              <label
                for="appointment-date"
                class="block text-sm font-medium text-slate-700 mb-2"
              >
                Preferred Appointment Date
              </label>
              <input
                type="date"
                id="appointment-date"
                name="appointmentDate"
                aria-describedby="date-hint"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors duration-200"
              />
              <p id="date-hint" class="mt-1 text-sm text-slate-500">
                We'll do our best to accommodate your preferred date.
              </p>
            </div>

            <!-- Message -->
            <div>
              <label
                for="message"
                class="block text-sm font-medium text-slate-700 mb-2"
              >
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                aria-describedby="message-hint"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors duration-200 resize-y"
                placeholder="Tell us about your dental needs or any questions you have..."
              ></textarea>
              <p id="message-hint" class="mt-1 text-sm text-slate-500">
                Optional: Include any specific concerns or questions.
              </p>
            </div>

            <!-- Required Fields Note -->
            <p class="text-sm text-slate-500">
              <span class="text-red-500" aria-hidden="true">*</span> Required fields
            </p>

            <!-- Submit Button -->
            <button
              type="submit"
              class="w-full bg-sky-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-sky-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 transition-colors duration-200 shadow-md"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Office Information -->
        <div class="space-y-8">
          <div>
            <h3 id="office-info-heading" class="text-2xl font-bold text-slate-800 mb-6">
              Office Information
            </h3>

            <div class="space-y-6">
              <!-- Address -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-sky-100 rounded-lg flex items-center justify-center">
                  <svg aria-hidden="true" class="w-6 h-6 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-slate-800">Address</h4>
                  <address class="not-italic text-slate-600">
                    123 Main Street, Suite 100<br />
                    Franconia, NH 03580
                  </address>
                </div>
              </div>

              <!-- Phone -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-sky-100 rounded-lg flex items-center justify-center">
                  <svg aria-hidden="true" class="w-6 h-6 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-slate-800">Phone</h4>
                  <a
                    href="tel:+15551234567"
                    class="text-sky-600 hover:text-sky-700 hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 rounded"
                  >
                    (555) 123-4567
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-sky-100 rounded-lg flex items-center justify-center">
                  <svg aria-hidden="true" class="w-6 h-6 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-slate-800">Email</h4>
                  <a
                    href="mailto:info@franconiafamilydental.com"
                    class="text-sky-600 hover:text-sky-700 hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 rounded"
                  >
                    info@franconiafamilydental.com
                  </a>
                </div>
              </div>

              <!-- Hours Summary -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-sky-100 rounded-lg flex items-center justify-center">
                  <svg aria-hidden="true" class="w-6 h-6 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-slate-800">Office Hours</h4>
                  <ul class="text-slate-600 space-y-1">
                    <li>Mon – Fri: 8:00 AM – 5:00 PM</li>
                    <li>Saturday: 9:00 AM – 1:00 PM</li>
                    <li>Sunday: Closed</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Google Maps Placeholder -->
          <div>
            <h4 id="map-heading" class="font-semibold text-slate-800 mb-4">Find Us</h4>
            <div
              aria-labelledby="map-heading"
              class="bg-slate-200 rounded-xl h-72 flex items-center justify-center border border-slate-300 overflow-hidden"
            >
              <div class="text-center p-6">
                <svg
                  aria-hidden="true"
                  class="w-12 h-12 text-slate-400 mx-auto mb-3"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
                <p class="text-slate-500 font-medium">Google Maps Embed</p>
                <p class="text-slate-400 text-sm mt-1">Replace with actual embed code</p>
              </div>
              <!--
                To embed Google Maps, replace the placeholder above with:
                <iframe
                  src="https://www.google.com/maps/embed?pb=YOUR_EMBED_URL"
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Franconia Family Dental office location"
                ></iframe>
              -->
            </div>
          </div>

          <!-- Emergency Note -->
          <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <svg aria-hidden="true" class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-amber-800">Dental Emergency?</h4>
                <p class="text-amber-700 text-sm mt-1">
                  If you're experiencing a dental emergency, please call us immediately at
                  <a
                    href="tel:+15551234567"
                    class="font-semibold underline hover:no-underline focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2 rounded"
                  >
                    (555) 123-4567
                  </a>.
                  We offer same-day emergency appointments when possible.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA Section -->
  <section
    aria-labelledby="cta-heading"
    class="bg-slate-50 py-16"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cta-heading" class="text-3xl font-bold text-slate-800 mb-4">
        Ready to Schedule Your Visit?
      </h2>
      <p class="text-lg text-slate-600 mb-8 max-w-2xl mx-auto">
        We're accepting new patients and would love to welcome you to our dental family.
        Book your appointment today and experience the Franconia Family Dental difference.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/book-appointment"
          class="inline-flex items-center justify-center bg-sky-600 text-white font-semibold py-3 px-8 rounded-lg hover:bg-sky-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 transition-colors duration-200 shadow-md"
        >
          Book Appointment
        </a>
        <a
          href="tel:+15551234567"
          class="inline-flex items-center justify-center bg-white text-sky-600 font-semibold py-3 px-8 rounded-lg border-2 border-sky-600 hover:bg-sky-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 transition-colors duration-200"
        >
          <svg aria-hidden="true" class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (555) 123-4567
        </a>
      </div>
    </div>
  </section>
</Layout>