---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Franconia Family Dental | Compassionate Family Dentistry"
  description="At Franconia Family Dental, we provide gentle, comprehensive dental care in a warm, welcoming environment. From routine checkups to advanced treatments, we're here for every member of your family."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-b from-sky-50 to-white">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Text Content -->
        <div class="text-center lg:text-left">
          <h1
            class="text-balance text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl"
          >
            Your Family's Smile is
            <span class="text-sky-600">Our Priority</span>
          </h1>
          <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 leading-relaxed lg:mx-0">
            At Franconia Family Dental, we provide gentle, comprehensive dental
            care in a warm, welcoming environment. From routine checkups to
            advanced treatments, we're here for every member of your family.
          </p>
          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row lg:justify-start">
            <a href="/book-appointment"
              class="inline-flex w-full items-center justify-center rounded-lg bg-sky-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-sky-500/25 transition-all hover:bg-sky-800 hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 active:scale-[0.98] sm:w-auto"
            >
              Book Your Appointment
            </a>
            <a href="/services"
              class="inline-flex w-full items-center justify-center rounded-lg border-2 border-slate-200 bg-white px-8 py-4 text-base font-semibold text-slate-700 transition-all hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 sm:w-auto"
            >
              Explore Services
            </a>
          </div>
        </div>

        <!-- Hero Image -->
        <div class="relative">
          <div class="relative overflow-hidden rounded-2xl shadow-2xl">
            <img
              src="/hero.jpg"
              alt="A friendly dentist consulting with a patient in a bright, modern dental office"
              class="w-full h-auto object-cover aspect-[4/3]"
              loading="eager"
              width="800"
              height="600"
            />
          </div>
          <div
            class="absolute -bottom-4 -right-4 -z-10 h-full w-full rounded-2xl bg-sky-100"
            aria-hidden="true"
          ></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="bg-white py-20" aria-labelledby="features-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2
          id="features-heading"
          class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
        >
          Why Choose Franconia Family Dental?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
          We combine modern technology with compassionate care to give you the
          best dental experience.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Feature 1 -->
        <div class="rounded-2xl border border-slate-100 bg-white p-8 shadow-sm transition-shadow hover:shadow-md">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"></path>
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-semibold text-slate-900">Gentle Care</h3>
          <p class="mt-3 text-slate-600 leading-relaxed">
            We understand dental anxiety. Our team creates a calming
            environment and takes extra care to ensure your comfort.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="rounded-2xl border border-slate-100 bg-white p-8 shadow-sm transition-shadow hover:shadow-md">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path>
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-semibold text-slate-900">Family Focused</h3>
          <p class="mt-3 text-slate-600 leading-relaxed">
            From toddlers to grandparents, we provide comprehensive care for
            patients of all ages in one convenient location.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="rounded-2xl border border-slate-100 bg-white p-8 shadow-sm transition-shadow hover:shadow-md">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"></path>
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-semibold text-slate-900">Modern Technology</h3>
          <p class="mt-3 text-slate-600 leading-relaxed">
            We use the latest dental technology for more accurate diagnoses,
            effective treatments, and faster recovery times.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-sky-700 py-16 relative overflow-hidden" aria-labelledby="cta-heading">

    <!-- Dancing tooth -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <style>
        @keyframes toothWalk {
          0%   { transform: translateX(-80px) translateY(0px) rotate(-5deg); opacity: 0; }
          3%   { opacity: 1; }
          20%  { transform: translateX(15vw)  translateY(-18px) rotate(8deg); }
          35%  { transform: translateX(28vw)  translateY(0px)   rotate(-6deg); }
          50%  { transform: translateX(42vw)  translateY(-20px) rotate(10deg); }
          65%  { transform: translateX(58vw)  translateY(0px)   rotate(-8deg); }
          80%  { transform: translateX(72vw)  translateY(-16px) rotate(6deg); }
          93%  { transform: translateX(88vw)  translateY(0px)   rotate(-4deg); opacity: 1; }
          97%  { opacity: 0; }
          100% { transform: translateX(105vw) translateY(0px)   rotate(5deg);  opacity: 0; }
        }
        @keyframes toothBob {
          0%, 100% { transform: scaleY(1); }
          50%       { transform: scaleY(0.92); }
        }
        .dancing-tooth {
          position: absolute;
          bottom: 12px;
          left: 0;
          width: 48px;
          height: 48px;
          animation: toothWalk 9s ease-in-out infinite;
        }
        .dancing-tooth svg {
          animation: toothBob 0.45s ease-in-out infinite alternate;
          transform-origin: bottom center;
        }
        @media (prefers-reduced-motion: reduce) {
          .dancing-tooth { animation: none; opacity: 0; }
          .dancing-tooth svg { animation: none; }
        }
      </style>

      <div class="dancing-tooth">
        <svg viewBox="0 0 48 60" width="48" height="60" xmlns="http://www.w3.org/2000/svg">
          <!-- Tooth body -->
          <path
            d="M24 4 C14 4 8 10 8 18 C8 22 9 25 10 28 C11 32 11 38 12 42 C13 47 15 52 17 52 C19 52 20 48 21 44 C22 40 22 38 24 38 C26 38 26 40 27 44 C28 48 29 52 31 52 C33 52 35 47 36 42 C37 38 37 32 38 28 C39 25 40 22 40 18 C40 10 34 4 24 4Z"
            fill="white"
            stroke="#bae6fd"
            stroke-width="1.5"
          />
          <!-- Shine left -->
          <path
            d="M14 12 C14 10 16 8 18 9"
            fill="none"
            stroke="#e0f2fe"
            stroke-width="2"
            stroke-linecap="round"
          />
          <!-- Shine small -->
          <circle cx="19" cy="15" r="1.5" fill="#e0f2fe" />
          <!-- Cute smile -->
          <path
            d="M19 26 Q24 30 29 26"
            fill="none"
            stroke="#93c5fd"
            stroke-width="1.8"
            stroke-linecap="round"
          />
          <!-- Eyes -->
          <circle cx="20" cy="21" r="1.8" fill="#7dd3fc" />
          <circle cx="28" cy="21" r="1.8" fill="#7dd3fc" />
          <!-- Eye shine -->
          <circle cx="20.8" cy="20.2" r="0.6" fill="white" />
          <circle cx="28.8" cy="20.2" r="0.6" fill="white" />
          <!-- Rosy cheeks -->
          <circle cx="16" cy="24" r="2.5" fill="#fda4af" opacity="0.5" />
          <circle cx="32" cy="24" r="2.5" fill="#fda4af" opacity="0.5" />
          <!-- Little arms waving -->
          <path d="M8 22 Q3 18 5 14" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" />
          <path d="M40 22 Q45 18 43 14" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" />
          <!-- Little legs -->
          <path d="M20 52 Q18 56 16 58" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" />
          <path d="M28 52 Q30 56 32 58" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" />
        </svg>
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center justify-between gap-6 lg:flex-row">
        <div class="text-center lg:text-left">
          <h2 id="cta-heading" class="text-2xl font-bold text-white sm:text-3xl">
            Ready to Schedule Your Visit?
          </h2>
          <p class="mt-2 text-white">
            New patients welcome! Call us or book online today.
          </p>
        </div>
        <div class="flex flex-col items-center gap-4 sm:flex-row">
          <a href="tel:+15551234567"
            class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 font-semibold text-sky-700 shadow-lg transition-all hover:bg-sky-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-sky-700"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"></path>
            </svg>
            (555) 123-4567
          </a>
          <a href="/book-appointment"
            class="inline-flex items-center rounded-lg border-2 border-white bg-transparent px-6 py-3 font-semibold text-white transition-all hover:bg-white hover:text-sky-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-sky-700"
          >
            Book Online
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>