---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Emergency Dental Care | Franconia Family Dental"
  description="Dental emergency in Franconia, NH? Franconia Family Dental offers same-day emergency appointments for toothaches, broken teeth, and urgent dental needs."
>
  <!-- Hero Section -->
  <section
    class="bg-gradient-to-b from-sky-50 to-white py-16 md:py-24"
    aria-labelledby="hero-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <a
          href="/services"
          class="inline-flex items-center gap-2 text-sm font-medium text-sky-600 hover:text-sky-700 mb-6 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 rounded"
        >
          <svg aria-hidden="true" class="h-4 w-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
          All Services
        </a>
        <h1
          id="hero-heading"
          class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl"
        >
          Emergency Dental Care
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600">
          Dental emergencies don't wait for convenient times. We offer same-day
          emergency appointments so you get the care you need when you need it most.
        </p>
      </div>
    </div>
  </section>

  <!-- Emergency Call Banner -->
  <div class="bg-red-50 border-y border-red-100">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center justify-center gap-4 text-center sm:flex-row sm:text-left">
        <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-red-100">
          <svg aria-hidden="true" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <div>
          <p class="font-semibold text-red-900">Experiencing a dental emergency?</p>
          <p class="text-red-700 text-sm">Call us immediately — we'll do our best to see you the same day.</p>
        </div>
        <a
          href="tel:+15551234567"
          class="inline-flex items-center gap-2 rounded-lg bg-red-600 px-6 py-2.5 font-semibold text-white hover:bg-red-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2 flex-shrink-0"
        >
          Call (555) 123-4567
        </a>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <section
    class="bg-white py-16 md:py-20"
    aria-labelledby="services-detail-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-start">
        <div>
          <h2 id="services-detail-heading" class="text-2xl font-bold text-slate-900 sm:text-3xl">
            We Treat All Dental Emergencies
          </h2>
          <p class="mt-4 text-slate-600 leading-relaxed">
            If you're in pain or have had a dental injury, don't wait. Call us right away
            and we'll get you in as quickly as possible. Prompt treatment can often save
            a tooth that might otherwise be lost.
          </p>

          <ul class="mt-8 space-y-4" role="list">
            {[
              { title: "Severe Toothache", desc: "Persistent or severe tooth pain can indicate infection or damage that needs immediate attention." },
              { title: "Knocked-Out Tooth", desc: "Time is critical — if you act quickly, we may be able to save and re-implant the tooth." },
              { title: "Chipped or Broken Tooth", desc: "We'll repair the damage and relieve any pain as quickly as possible." },
              { title: "Lost Filling or Crown", desc: "A lost restoration can expose sensitive tooth structure — we'll fix it fast." },
              { title: "Dental Abscess", desc: "A serious infection that requires immediate treatment to prevent it from spreading." },
              { title: "Soft Tissue Injuries", desc: "Cuts or lacerations to the lips, gums, tongue, or cheeks require prompt care." },
            ].map((item) => (
              <li class="flex items-start gap-4">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-sky-100">
                  <svg aria-hidden="true" class="h-4 w-4 text-sky-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <strong class="text-slate-900">{item.title}</strong>
                  <p class="mt-1 text-sm text-slate-600">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <div class="space-y-6">
          <div class="rounded-2xl bg-sky-50 p-8">
            <h3 class="text-lg font-bold text-slate-900">Knocked Out a Tooth? Act Fast.</h3>
            <ol class="mt-3 space-y-3 text-slate-600 text-sm">
              <li class="flex items-start gap-3">
                <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-sky-600 text-xs font-bold text-white">1</span>
                <span>Pick up the tooth by the crown, not the root</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-sky-600 text-xs font-bold text-white">2</span>
                <span>Rinse gently with water — do not scrub</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-sky-600 text-xs font-bold text-white">3</span>
                <span>Keep it moist — in milk or between your cheek and gum</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-sky-600 text-xs font-bold text-white">4</span>
                <span>Call us immediately and get to our office within 30 minutes</span>
              </li>
            </ol>
          </div>

          <div class="rounded-2xl bg-amber-50 border border-amber-200 p-8">
            <h3 class="text-lg font-bold text-amber-900">After-Hours Emergencies</h3>
            <p class="mt-3 text-amber-800 text-sm leading-relaxed">
              For after-hours emergencies, call our main number. Our answering service
              will connect you with the on-call dentist who can advise you on next steps
              until we can see you in the office.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-sky-600 py-16" aria-labelledby="cta-heading">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cta-heading" class="text-2xl font-bold text-white sm:text-3xl">
        Don't Wait — Call Us Now
      </h2>
      <p class="mt-4 text-sky-100">
        We'll do everything we can to see you the same day and get you out of pain fast.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="tel:+15551234567"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-8 py-3.5 text-base font-semibold text-sky-600 shadow-sm transition-all hover:bg-sky-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-sky-600"
        >
          <svg aria-hidden="true" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          Call (555) 123-4567
        </a>
        <a
          href="/book-appointment"
          class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/30 bg-transparent px-8 py-3.5 text-base font-semibold text-white transition-all hover:border-white hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-sky-600"
        >
          Request Appointment Online
        </a>
      </div>
    </div>
  </section>
</Layout>