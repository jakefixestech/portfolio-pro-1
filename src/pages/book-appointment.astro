---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Book Your Appointment | Franconia Family Dental"
  description="Schedule your dental appointment at Franconia Family Dental. New and existing patients welcome. We'll confirm your appointment within 24 hours."
>
  <!-- Page Hero -->
  <section aria-labelledby="hero-heading" class="bg-gradient-to-br from-sky-600 to-sky-700 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 id="hero-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-balance">
        Book Your Appointment
      </h1>
      <p class="text-lg md:text-xl text-sky-100 max-w-2xl mx-auto text-pretty">
        Taking the first step toward better dental health is easy. Fill out the form below and our team
        will contact you to confirm your appointment. We look forward to seeing you!
      </p>
    </div>
  </section>

  <!-- Booking Form Section -->
  <section aria-labelledby="booking-form-heading" class="py-16 md:py-20 bg-slate-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="booking-form-heading" class="sr-only">Appointment Booking Form</h2>

      <div class="bg-white rounded-2xl shadow-lg p-6 md:p-10">
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-sky-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-sky-600" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-800">Request an Appointment</h3>
          <p class="text-slate-600 mt-1">
            All fields marked with <span class="text-red-600" aria-hidden="true">*</span>
            <span class="sr-only">an asterisk</span> are required
          </p>
        </div>

        <form action="/api/book-appointment" method="POST" class="space-y-6">
          <!-- Name Fields -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="first-name" class="block text-sm font-medium text-slate-700 mb-1">
                First Name <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="first-name"
                name="firstName"
                required
                aria-required="true"
                autocomplete="given-name"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors"
                placeholder="John"
              />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-slate-700 mb-1">
                Last Name <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="last-name"
                name="lastName"
                required
                aria-required="true"
                autocomplete="family-name"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors"
                placeholder="Smith"
              />
            </div>
          </div>

          <!-- Email Field -->
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">
              Email Address <span class="text-red-600" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              aria-required="true"
              aria-describedby="email-hint"
              autocomplete="email"
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors"
              placeholder="john.smith@example.com"
            />
            <p id="email-hint" class="mt-1 text-sm text-slate-500">
              We'll send your appointment confirmation here
            </p>
          </div>

          <!-- Phone Field -->
          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">
              Phone Number <span class="text-red-600" aria-hidden="true">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              aria-required="true"
              aria-describedby="phone-hint"
              autocomplete="tel"
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors"
              placeholder="(555) 123-4567"
            />
            <p id="phone-hint" class="mt-1 text-sm text-slate-500">
              For appointment reminders and follow-ups
            </p>
          </div>

          <!-- Patient Status Radio Group -->
          <fieldset>
            <legend class="block text-sm font-medium text-slate-700 mb-3">
              Are you a new or existing patient? <span class="text-red-600" aria-hidden="true">*</span>
            </legend>
            <div class="flex flex-wrap gap-4">
              <div class="flex items-center">
                <input
                  type="radio"
                  id="new-patient"
                  name="patientStatus"
                  value="new"
                  required
                  aria-required="true"
                  class="w-4 h-4 text-sky-600 border-slate-300 focus:ring-sky-500 focus:ring-2"
                />
                <label for="new-patient" class="ml-2 text-slate-700">
                  New Patient
                </label>
              </div>
              <div class="flex items-center">
                <input
                  type="radio"
                  id="existing-patient"
                  name="patientStatus"
                  value="existing"
                  class="w-4 h-4 text-sky-600 border-slate-300 focus:ring-sky-500 focus:ring-2"
                />
                <label for="existing-patient" class="ml-2 text-slate-700">
                  Existing Patient
                </label>
              </div>
            </div>
          </fieldset>

          <!-- Service Select -->
          <div>
            <label for="service" class="block text-sm font-medium text-slate-700 mb-1">
              Service Needed <span class="text-red-600" aria-hidden="true">*</span>
            </label>
            <select
              id="service"
              name="service"
              required
              aria-required="true"
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors bg-white"
            >
              <option value="">Select a service...</option>
              <option value="general-dentistry">General Dentistry</option>
              <option value="cosmetic-dentistry">Cosmetic Dentistry</option>
              <option value="pediatric-dentistry">Pediatric Dentistry</option>
              <option value="orthodontics">Orthodontics</option>
              <option value="emergency-care">Emergency Dental Care</option>
              <option value="teeth-whitening">Teeth Whitening</option>
            </select>
          </div>

          <!-- Date and Time Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="preferred-date" class="block text-sm font-medium text-slate-700 mb-1">
                Preferred Date <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <input
                type="date"
                id="preferred-date"
                name="preferredDate"
                required
                aria-required="true"
                aria-describedby="date-hint"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors"
              />
              <p id="date-hint" class="mt-1 text-sm text-slate-500">
                We're open Mon–Sat
              </p>
            </div>
            <div>
              <label for="preferred-time" class="block text-sm font-medium text-slate-700 mb-1">
                Preferred Time <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <select
                id="preferred-time"
                name="preferredTime"
                required
                aria-required="true"
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors bg-white"
              >
                <option value="">Select a time...</option>
                <option value="morning">Morning (8am – 12pm)</option>
                <option value="afternoon">Afternoon (12pm – 4pm)</option>
                <option value="evening">Evening (4pm – 6pm)</option>
              </select>
            </div>
          </div>

          <!-- Additional Notes -->
          <div>
            <label for="notes" class="block text-sm font-medium text-slate-700 mb-1">
              Additional Notes
            </label>
            <textarea
              id="notes"
              name="notes"
              rows="4"
              aria-describedby="notes-hint"
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 transition-colors resize-y"
              placeholder="Any special concerns, accessibility needs, or specific requests..."
            ></textarea>
            <p id="notes-hint" class="mt-1 text-sm text-slate-500">
              Optional: Let us know if you have any specific concerns or needs
            </p>
          </div>

          <!-- Submit Button -->
          <div class="pt-4">
            <button
              type="submit"
              class="w-full bg-sky-600 text-white font-semibold py-4 px-6 rounded-lg hover:bg-sky-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 transition-colors text-lg"
            >
              Request Appointment
            </button>
            <p class="text-center text-sm text-slate-500 mt-3">
              By submitting, you agree to our
              <a
                href="/privacy-policy"
                class="text-sky-600 hover:text-sky-700 underline focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 rounded"
              >
                Privacy Policy
              </a>
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Trust/Reassurance Section -->
  <section aria-labelledby="reassurance-heading" class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="reassurance-heading" class="sr-only">Why Book With Us</h2>

      <ul role="list" class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <li class="flex flex-col items-center text-center">
          <div class="w-14 h-14 bg-sky-100 rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-sky-600" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">Confirmed Within 24 Hours</h3>
          <p class="text-slate-600">
            Our team will reach out to confirm your appointment within one business day.
          </p>
        </li>

        <li class="flex flex-col items-center text-center">
          <div class="w-14 h-14 bg-sky-100 rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-sky-600" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">Easy Rescheduling</h3>
          <p class="text-slate-600">
            Need to change your appointment? No problem. We make rescheduling simple and stress-free.
          </p>
        </li>

        <li class="flex flex-col items-center text-center">
          <div class="w-14 h-14 bg-sky-100 rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-sky-600" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">New Patients Welcome</h3>
          <p class="text-slate-600">
            We love meeting new patients! Our team will ensure your first visit is comfortable and welcoming.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Contact Info Banner -->
  <section aria-labelledby="contact-banner-heading" class="py-10 bg-slate-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="contact-banner-heading" class="text-xl font-semibold text-slate-800 mb-4">
        Prefer to Call?
      </h2>
      <p class="text-slate-600 mb-4">
        Our friendly staff is ready to help you schedule your appointment over the phone.
      </p>
      <a
        href="tel:+15551234567"
        class="inline-flex items-center gap-2 text-2xl font-bold text-sky-600 hover:text-sky-700 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 rounded"
      >
        <svg class="w-6 h-6" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        (555) 123-4567
      </a>
      <p class="text-sm text-slate-500 mt-2">
        Mon–Fri: 8:00 AM – 5:00 PM &nbsp;|&nbsp; Sat: 9:00 AM – 1:00 PM
      </p>
    </div>
  </section>
</Layout>