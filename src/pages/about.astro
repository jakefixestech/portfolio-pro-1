---
import Layout from "../layouts/Layout.astro";

const teamMembers = [
  {
    id: "dr-chen",
    name: "Dr. Sarah Chen, DDS",
    title: "Lead Dentist & Founder",
    initials: "SC",
    color: "bg-sky-600",
    bio: "With over 15 years of experience in family and cosmetic dentistry, Dr. Chen founded Franconia Family Dental to provide compassionate, patient-centered care. She earned her Doctor of Dental Surgery from Virginia Commonwealth University and is passionate about creating comfortable experiences for patients of all ages.",
  },
  {
    id: "dr-martinez",
    name: "Dr. Michael Martinez, DMD",
    title: "Associate Dentist",
    initials: "MM",
    color: "bg-slate-700",
    bio: "Dr. Martinez specializes in pediatric dentistry and preventive care. A graduate of the University of Maryland School of Dentistry, he brings a gentle approach that helps even the most anxious patients feel at ease. He's dedicated to educating families about oral health.",
  },
  {
    id: "lisa-thompson",
    name: "Lisa Thompson, RDH",
    title: "Lead Dental Hygienist",
    initials: "LT",
    color: "bg-sky-500",
    bio: "Lisa has been part of our team for over 8 years, providing thorough yet gentle cleanings and personalized hygiene education. Her warm demeanor and attention to detail make every visit comfortable, and she's committed to helping patients achieve their best smile.",
  },
];

const values = [
  {
    id: "compassion",
    title: "Compassion",
    description:
      "We understand that visiting the dentist can be stressful. Our team provides gentle, empathetic care that puts your comfort first, ensuring every patient feels heard and valued.",
    icon: "heart",
  },
  {
    id: "integrity",
    title: "Integrity",
    description:
      "We believe in honest, transparent communication about your dental health. We'll always explain your options clearly and recommend only the treatments you truly need.",
    icon: "shield",
  },
  {
    id: "community",
    title: "Community",
    description:
      "As a local family practice, we're proud to serve the Franconia community. We build lasting relationships with our patients and participate in local outreach programs.",
    icon: "users",
  },
  {
    id: "excellence",
    title: "Excellence",
    description:
      "We invest in continuing education and modern technology to provide the highest standard of care. Your health and satisfaction are our top priorities.",
    icon: "star",
  },
];
---

<Layout
  title="About Our Practice | Franconia Family Dental"
  description="Learn about Franconia Family Dental, our experienced team, core values, and commitment to providing compassionate dental care for the whole family."
>
  <!-- Hero Section -->
  <section
    class="bg-gradient-to-b from-sky-50 to-white py-16 sm:py-20 lg:py-24"
    aria-labelledby="hero-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1
          id="hero-heading"
          class="text-balance text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl"
        >
          About Our Practice
        </h1>
        <p class="mt-6 text-pretty text-lg leading-relaxed text-slate-600 sm:text-xl">
          At Franconia Family Dental, we believe everyone deserves a healthy,
          beautiful smile. For over a decade, we've been providing comprehensive
          dental care to families in our community with warmth, expertise, and a
          commitment to your comfort. From your first visit, you'll experience
          the difference that truly personalized care can make.
        </p>
      </div>
    </div>
  </section>

  <!-- Meet the Team Section -->
  <section
    class="py-16 sm:py-20 lg:py-24"
    aria-labelledby="team-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2
          id="team-heading"
          class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl"
        >
          Meet the Team
        </h2>
        <p class="mt-4 text-slate-600">
          Our dedicated professionals bring years of experience and a genuine
          passion for helping you achieve optimal oral health.
        </p>
      </div>

      <ul
        class="mx-auto mt-12 grid max-w-5xl gap-8 sm:grid-cols-2 lg:grid-cols-3"
        role="list"
      >
        {
          teamMembers.map((member) => (
            <li>
              <article
                class="flex h-full flex-col rounded-2xl bg-white p-6 shadow-md shadow-slate-200/50 ring-1 ring-slate-100 transition-shadow hover:shadow-lg"
                aria-labelledby={`${member.id}-name`}
              >
                <div class="flex flex-col items-center text-center">
                  <!-- Initial Badge -->
                  <div
                    class={`flex h-24 w-24 items-center justify-center rounded-full ${member.color}`}
                    aria-hidden="true"
                  >
                    <span class="text-2xl font-bold text-white tracking-wide">
                      {member.initials}
                    </span>
                  </div>

                  <h3
                    id={`${member.id}-name`}
                    class="mt-4 text-lg font-semibold text-slate-900"
                  >
                    {member.name}
                  </h3>
                  <p class="text-sm font-medium text-sky-600">{member.title}</p>
                </div>

                <p class="mt-4 flex-1 text-center text-sm leading-relaxed text-slate-600">
                  {member.bio}
                </p>
              </article>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Our Values Section -->
  <section
    class="bg-slate-50 py-16 sm:py-20 lg:py-24"
    aria-labelledby="values-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2
          id="values-heading"
          class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl"
        >
          Our Values
        </h2>
        <p class="mt-4 text-slate-600">
          The principles that guide everything we do at Franconia Family Dental.
        </p>
      </div>

      <ul
        class="mx-auto mt-12 grid max-w-5xl gap-6 sm:grid-cols-2 lg:gap-8"
        role="list"
      >
        {
          values.map((value) => (
            <li>
              <div class="flex h-full gap-4 rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-100">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-sky-100">
                  {value.icon === "heart" && (
                    <svg class="h-6 w-6 text-sky-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                    </svg>
                  )}
                  {value.icon === "shield" && (
                    <svg class="h-6 w-6 text-sky-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                    </svg>
                  )}
                  {value.icon === "users" && (
                    <svg class="h-6 w-6 text-sky-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                    </svg>
                  )}
                  {value.icon === "star" && (
                    <svg class="h-6 w-6 text-sky-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                    </svg>
                  )}
                </div>
                <div class="flex-1">
                  <h3 id={`${value.id}-title`} class="font-semibold text-slate-900">
                    {value.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-slate-600">
                    {value.description}
                  </p>
                </div>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Our Office Section -->
  <section
    class="py-16 sm:py-20 lg:py-24"
    aria-labelledby="office-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2
            id="office-heading"
            class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl"
          >
            Our Office
          </h2>
          <div class="mt-6 space-y-4 text-slate-600">
            <p class="leading-relaxed">
              Our modern, welcoming office is designed with your comfort in
              mind. Located in the heart of Franconia, we've created a calm,
              inviting space where patients of all ages can feel at ease.
            </p>
            <p class="leading-relaxed">
              We've invested in state-of-the-art dental technology including
              digital X-rays, intraoral cameras, and comfortable treatment
              chairs. Our private treatment rooms, soothing decor, and friendly
              atmosphere help make every visit a positive experience.
            </p>
            <p class="leading-relaxed">
              Convenient parking and accessible entrances ensure that visiting
              us is easy for everyone. We look forward to welcoming you and your
              family to our practice.
            </p>
          </div>

          <a
            href="/contact"
            class="mt-8 inline-flex items-center gap-2 rounded-lg bg-sky-600 px-6 py-3 font-semibold text-white shadow-sm transition-all hover:bg-sky-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 active:scale-[0.98]"
          >
            Visit Us Today
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
            </svg>
          </a>
        </div>

        <!-- Office Photo -->
        <div class="relative">
          <div class="overflow-hidden rounded-2xl shadow-lg ring-1 ring-slate-200">
            <img
              src="/office.jpg"
              alt="Bright, modern waiting room at Franconia Family Dental with comfortable blue chairs and natural light"
              class="w-full h-auto object-cover aspect-[4/3]"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
          <div
            class="absolute -bottom-4 -right-4 -z-10 h-full w-full rounded-2xl bg-sky-100"
            aria-hidden="true"
          ></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section
    class="bg-sky-600 py-16 sm:py-20"
    aria-labelledby="cta-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2
          id="cta-heading"
          class="text-balance text-2xl font-bold tracking-tight text-white sm:text-3xl"
        >
          Ready to Experience the Difference?
        </h2>
        <p class="mt-4 text-sky-100">
          Join our family of patients and discover why Franconia families have
          trusted us with their smiles for over a decade.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/book-appointment"
            class="inline-flex w-full items-center justify-center rounded-lg bg-white px-6 py-3 font-semibold text-sky-600 shadow-sm transition-all hover:bg-sky-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-sky-600 active:scale-[0.98] sm:w-auto"
          >
            Schedule Your Visit
          </a>
          <a
            href="/contact"
            class="inline-flex w-full items-center justify-center rounded-lg border-2 border-white/30 bg-transparent px-6 py-3 font-semibold text-white transition-all hover:border-white hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-sky-600 sm:w-auto"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>